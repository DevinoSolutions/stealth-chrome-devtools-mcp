# stealth-chrome-devtools-mcp - environment configuration
#
# This file documents EVERY variable the Settings model
# (src/stealth_chrome_devtools_mcp/settings.py) reads. Copy it to `.env` and
# uncomment the keys you want to override. Values shown are the defaults.
#
# Strict schema (zod-style): an unknown STEALTH_MCP_* key - or ANY unknown key
# placed in a real `.env` - fails loudly at startup. Explicit CLI flags still
# override these env-supplied defaults.

# -- Application config (STEALTH_MCP_* namespace) ---------------------------
# Disable automatic orphaned-process recovery at startup.
STEALTH_MCP_NO_AUTO_RECOVERY=false
# Directory for clone / large-response output artifacts (default: per-user temp).
#STEALTH_MCP_CLONE_OUTPUT_DIR=
# Root directory for per-browser disk sessions (default: platform-specific).
#STEALTH_MCP_BROWSER_SESSION_ROOT=
# Storage cap (GB) for profile clones before eviction.
STEALTH_MCP_CLONE_STORAGE_CAP_GB=10.0
# Retention (hours) for trashed clones before permanent deletion.
STEALTH_MCP_CLONE_TRASH_RETENTION_HOURS=24.0
# Storage cap (GB) for browser sessions before eviction.
STEALTH_MCP_SESSION_STORAGE_CAP_GB=20.0
# Directory for M3 observability file logs (default: ~/.stealth-mcp/logs).
#STEALTH_MCP_LOG_DIR=
# Minimum level recorded by the M3 file logger (DEBUG/INFO/WARNING/ERROR/CRITICAL).
STEALTH_MCP_LOG_LEVEL=INFO
# Capture response bodies (metadata is always captured). OFF by default (F-605):
# get_response_content still live-refetches; search/export bodies stay empty until on.
STEALTH_MCP_NETWORK_CAPTURE_BODIES=false
# Per-body cap in bytes; a larger body is stored metadata-only. 0 = no cap. (5 MiB)
STEALTH_MCP_NETWORK_BODY_MAX_BYTES=5242880
# Total response-body store cap in bytes; oldest bodies evicted first. 0 = no cap. (128 MiB)
STEALTH_MCP_NETWORK_BODY_STORE_MAX_BYTES=134217728

# -- Legacy-named config (no prefix; names preserved exactly) ---------------
# Real timeout (seconds) for the synchronous kill phase of close_instance.
CLOSE_KILL_TIMEOUT=5.0
# 0 = idle reaping disabled (never auto-close); the default for a persistent server.
BROWSER_IDLE_TIMEOUT=0
BROWSER_IDLE_REAPER_INTERVAL=60
CDP_OPERATION_TIMEOUT_SECONDS=30.0
EXECUTE_SCRIPT_TIMEOUT_SECONDS=10.0
MAX_USER_SCRIPT_BYTES=100000
BROWSER_STATE_TIMEOUT_SECONDS=10.0
STEALTH_BROWSER_DEBUG=false
DEBUG=false
#BROWSER_MASTER_USER_DATA_DIR=
#BROWSER_PROFILE_CLONE_ROOT=
#BROWSER_MASTER_SNAPSHOT_DIR=
BROWSER_PROFILE_REFRESH_DAYS=7
BROWSER_ORPHAN_PROFILE_MAX_AGE=21600
#STEALTH_CHROME_PROFILE_KEY=
#BROWSER_PROFILE_KEY=
PORT=8000
XPOOL_SAFE_MODE=false

# -- Host / runtime detection (normally auto-detected; override only for tests) --
#DISPLAY=
#container=
#KUBERNETES_SERVICE_HOST=
#USER=
#USERNAME=
#CODEX_WORKSPACE=
#CLAUDE_PROJECT_DIR=
#PWD=

# -- Observability (default OFF; local single-user tool) --------------------
# Set to a Sentry DSN to enable error reporting (default: disabled).
#SENTRY_DSN=
